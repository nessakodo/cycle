# Cycle Bot — US-Legal Configuration
# Kalshi (CFTC) + Tradier (Reg T) + Odds API
# Copy to .env and fill in your keys

# Kalshi (kalshi.com → Account → API Keys)
# Generate API key, upload PEM file to droplet, set path
KALSHI_API_KEY=your_api_key_id
# Path to uploaded PEM file on droplet (rename cycle.txt to kalshi_private_key.pem if needed)
KALSHI_PRIVATE_KEY_PATH=/home/nessa/cycle/kalshi_private_key.pem
# Demo: https://demo-api.kalshi.co/trade-api/v2
# Prod: https://trading-api.kalshi.com/trade-api/v2
KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2
# Fallback when discovery returns 0 (e.g. demo API): comma-separated tickers
# MANUAL_KALSHI_TICKERS=INX-25DEC24-5000,FED-26MAR24-CUT

# The Odds API (the-odds-api.com) — 6 keys for rotation, stay under 500/day free tier
ODDS_API_KEYS=key1,key2,key3,key4,key5,key6

# Finnhub (finnhub.io) — replaces Glassnode for price/volume/technical signals
FINNHUB_API_KEY=your_finnhub_key_here

# Tradier (tradier.com → API Access)
# Sandbox for paper, api.tradier.com for live
TRADIER_ACCESS_TOKEN=your_tradier_token
TRADIER_ACCOUNT_ID=your_account_id
TRADIER_BASE_URL=https://sandbox.tradier.com/v1

# Signal Feeds (optional)
NEWSAPI_KEY=
X_BEARER_TOKEN=

# Bot Settings
PAPER_MODE=true
SPREAD_BPS=50
MAX_INVENTORY_USDC=1000
QUOTE_SIZE_CONTRACTS=10
QUOTE_INTERVAL_SEC=5
PIVOT_INTERVAL_SEC=1800
