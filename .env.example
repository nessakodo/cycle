# Cycle Bot Configuration
# Copy this to .env and fill in your keys

# Polymarket (your wallet private key — EOA hex, with 0x prefix)
POLY_PRIVATE_KEY=0xYourPrivateKeyHere

# Kraken Futures API
KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_API_SECRET=your_kraken_api_secret

# Signal Feeds
GLASSNODE_API_KEY=your_glassnode_key
NEWSAPI_KEY=your_newsapi_key

# Optional: X/Twitter API (leave blank to skip)
X_BEARER_TOKEN=

# Proxy (optional — SOCKS5 or HTTP, e.g. socks5://127.0.0.1:1080)
PROXY_HTTP=
PROXY_HTTPS=

# Bot Settings
PAPER_MODE=true
SPREAD_BPS=50
MAX_INVENTORY_USDC=1000
HEDGE_LEVERAGE=3
QUOTE_SIZE_USDC=10
QUOTE_INTERVAL_SEC=5
PIVOT_INTERVAL_SEC=1800
MAX_FUNDING_RATE=0.0005
