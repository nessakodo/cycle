# Cycle Bot — US-Legal Configuration
# Kalshi (CFTC) + Tradier (Reg T) + Odds API
# Copy to .env and fill in your keys

# Kalshi (kalshi.com → Account → API Keys)
# Generate API key, download .pem file, set path
KALSHI_API_KEY=your_api_key_id
KALSHI_PRIVATE_KEY_PATH=/path/to/your/private_key.pem
# Demo: https://demo-api.kalshi.co/trade-api/v2
# Prod: https://trading-api.kalshi.com/trade-api/v2
KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2

# The Odds API (the-odds-api.com)
ODDS_API_KEY=your_odds_api_key

# Tradier (tradier.com → API Access)
# Sandbox for paper, api.tradier.com for live
TRADIER_ACCESS_TOKEN=your_tradier_token
TRADIER_ACCOUNT_ID=your_account_id
TRADIER_BASE_URL=https://sandbox.tradier.com/v1

# Signal Feeds (optional)
GLASSNODE_API_KEY=
NEWSAPI_KEY=
X_BEARER_TOKEN=

# Bot Settings
PAPER_MODE=true
SPREAD_BPS=50
MAX_INVENTORY_USDC=1000
QUOTE_SIZE_CONTRACTS=10
QUOTE_INTERVAL_SEC=5
PIVOT_INTERVAL_SEC=1800
